# Copy to .env.staging on the staging host (do not commit secrets).
# Production uses .env on :8000; staging uses this file on :8001 (see hibs-bet-staging.service).

HIBS_MAX_DATA=1
HIBS_CACHE_DIR=.cache-staging
HIBS_SCRAPE_XG=1
HIBS_ENABLE_SCOTTISH_FBREF_XG=1

# Optional: reverse proxy or local dev parity
# PORT=5002
